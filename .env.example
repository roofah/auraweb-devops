# ==========================================
# Environment Configuration
# ==========================================
# This file contains LOCAL DEVELOPMENT defaults.
# Copy this file to .env and customize as needed.

# ==========================================
# Application Settings
# ==========================================
NODE_ENV=development
APP_NAME=AuraWeb

# ==========================================
# Domain Configuration
# ==========================================
DOMAIN=localhost
FRONTEND_URL=http://localhost
ADMIN_URL=http://localhost/admin
API_URL=http://localhost:8080/api

# ==========================================
# Service URLs (Internal/Docker Compose)
# ==========================================
CATALOG_SERVICE_URL=http://catalog-service:3001
ORDER_PAYMENT_SERVICE_URL=http://order-payment-service:3002
FULFILLMENT_SERVICE_URL=http://fulfillment-service:3003
SHOPPING_SERVICE_URL=http://shopping-service:3004
PLATFORM_SERVICE_URL=http://platform-insights-service:3005
USER_COMM_SERVICE_URL=http://user-communication-service:3000
INVENTORY_SERVICE_URL=http://inventory-service:3006
GATEWAY_URL=http://gateway:8080

# ==========================================
# Security Settings
# ==========================================
# IMPORTANT: Generate strong secrets using: ./scripts/generate-secrets.sh
# DO NOT use these example values in production!

SECRET_KEY=REPLACE_WITH_STRONG_SECRET_FROM_generate-secrets.sh
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_FROM_generate-secrets.sh
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_SECRET_FROM_generate-secrets.sh

# ==========================================
# Infrastructure Configuration
# ==========================================
DB_HOST=database
DB_PORT=5432
DB_NAME=auraweb_db
DB_USER=auraweb_user
DB_PASSWORD=password

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

ELASTICSEARCH_URL=http://elasticsearch:9200
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_BUCKET_NAME=mybucket
AWS_REGION=us-east-1
AWS_ENDPOINT=http://minio:9000

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
